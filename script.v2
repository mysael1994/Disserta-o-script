############################################################
# 4. PADRONIZAÇÃO DAS BASES SISU
############################################################

padroniza_sisu <- function(df) {
  df %>%
    janitor::clean_names() %>%
    rename_with(~tolower(.)) %>%
    rename(
      ano_sisu = any_of(c("nu_ano", "ano")),
      edicao = any_of(c("nu_edicao", "edicao")),
      etapa_codigo = any_of(c("co_etapa", "etapa")),
      etapa_nome = any_of(c("ds_etapa")),
      
      id_ies = any_of(c("cod_ies", "co_ies", "codigo_ies")),
      nome_ies = any_of(c("ies", "no_ies", "nome_ies")),
      uf_ies = any_of(c("uf_ies", "sg_uf_ies")),
      
      id_campus = any_of(c("cod_campus", "co_campus", "codigo_campus")),
      nome_campus = any_of(c("campus", "no_campus", "nome_campus")),
      
      id_curso = any_of(c("codigo_curso", "co_ies_curso")),
      nome_curso = any_of(c("nome_curso", "no_curso")),
      
      cpf = any_of(c("cpf", "nu_cpf")),
      inscricao_enem = any_of(c("co_inscricao_enem", "inscricao_enem")),
      
      nome_candidato = any_of(c("no_inscrito", "inscrito")),
      sexo = any_of(c("tp_sexo", "sexo")),
      
      nota_l = any_of(c("nu_nota_l", "nota_l")),
      nota_ch = any_of(c("nu_nota_ch", "nota_ch")),
      nota_cn = any_of(c("nu_nota_cn", "nota_cn")),
      nota_m = any_of(c("nu_nota_m", "nota_m")),
      nota_r = any_of(c("nu_nota_r", "nota_r")),
      
      nota_final = any_of(c("nota_concorrencia", "nu_nota_candidato", "nota_candidato")),
      nota_corte = any_of(c("nu_notacorte", "nota_corte")),
      
      classificacao = any_of(c("nu_classificacao", "classificacao")),
      aprovado = any_of(c("st_aprovado", "aprovado"))
    )
}

sisu_2015_1 <- padroniza_sisu(sisu_2015_1)
sisu_2016_1 <- padroniza_sisu(sisu_2016_1)
sisu_2017_1 <- padroniza_sisu(sisu_2017_1)
sisu_2018_1 <- padroniza_sisu(sisu_2018_1)
sisu_2019_1 <- padroniza_sisu(sisu_2019_1)


