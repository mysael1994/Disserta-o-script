    color = ""
  ) +
  theme_minimal(base_size = 14)


#hipotese de Linearidade então posso considerar 
ggplot(
  tabela_linearidade,
  aes(
    x = tempo,
    y = cr_medio,
    color = factor(cota)
  )
) +
  geom_point(size = 3) +
  
  geom_smooth(
    method = "loess",
    se = FALSE,
    linewidth = 1.2
  ) +
  
  geom_smooth(
    method = "lm",
    linetype = 2,
    se = FALSE
  ) +
  
  scale_color_manual(
    values = c("#1F77B4", "#D62728"),
    labels = c(
      "Não cotistas",
      "Cotistas"
    )
  ) +
  
  scale_x_continuous(
    breaks = 1:10
  ) +
  
  labs(
    x = "Semestre cursado",
    y = "CR médio",
    color = ""
  ) +
  
  theme_minimal(base_size = 14)

getwd()

