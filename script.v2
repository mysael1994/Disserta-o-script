#realizando o modo clusterizados
#mod 1
modelo_catchup1 <- lm(
  cr_semestre ~
    cota * tempo +
    sexo.x +
    raca +
    idade_ingresso +
    dummyescolapublica +
    bolsa_assistencia +
    bolsa_institucional +
    unidade_responsavel,
  data = painel_total
)

coeftest(
  modelo_catchup1,
  vcov = vcovCL(
    modelo_catchup1,
    cluster = ~matricula
  )
)

