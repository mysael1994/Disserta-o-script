############################################################

sisu_2016_1 <- sisu_2016_1 %>%
  mutate(
    cpf_meio = str_remove_all(cpf, "[^0-9]")
  ) %>%
  filter(
    st_matricula == "EFETIVADA" |
      st_matricula == "SUBSTITUIDA"
  )

base16 <- subset(base, ano_ingresso == 2016)

merge2016 <- base16 %>%
  left_join(
