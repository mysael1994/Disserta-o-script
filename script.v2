############################################################
# 14. REGRESSÃO LOGÍSTICA - EVASÃO
############################################################

#ajustes para regressão
# Centralização da idade de ingresso
# (reduz a colinearidade entre idade e idade²)

base_final <- base_final %>%
  mutate(
    idade_ingresso_c =
      idade_ingresso -
      mean(idade_ingresso, na.rm = TRUE),
    
    idade_ingresso_c2 =
      idade_ingresso_c^2
  )

# Ano de ingresso como fator
base_final$ano_ingresso <- factor(base_final$ano_ingresso)


# 14.2 Modelo 1
# Características individuais
# (utilizado apenas para verificar a evolução do coeficiente
# da variável cota)


logit_m1 <- glm(
  evento ~
    cota +
    sexo.x +
    raca +
    idade_ingresso_c +
    idade_ingresso_c2,
  family = binomial(link = "logit"),
  data = base_final
)

summary(logit_m1)


# 14.3 Modelo 2 (MODELO PRINCIPAL)
# Acrescenta características institucionais e coorte
#
# Este será o modelo apresentado na dissertação.

logit_principal <- glm(
  evento ~
    cota +
    sexo.x +
    raca +
    idade_ingresso_c +
    idade_ingresso_c2 +
    dummyescolapublica +
    ano_ingresso +
    unidade_responsavel,
  family = binomial(link = "logit"),
  data = base_final
)

summary(logit_principal)

# Razão de chances (Odds Ratios)

exp(
  cbind(
    OR = coef(logit_principal),
    confint(logit_principal)
  )
)


# Diagnósticos do modelo principal


# Multicolinearidade

car::vif(logit_principal)

# Ajuste do modelo

ResourceSelection::hoslem.test(
  base_final$evento,
  fitted(logit_principal),
  g = 10
)


# 14.4 Modelo de Robustez
# Acrescenta ENEM
#
# Objetivo:
# verificar se os resultados permanecem quando
# controlamos a habilidade acadêmica inicial.
#
# Não será o modelo principal porque reduz
# significativamente a amostra.


logit_enem <- glm(
  evento ~
    cota +
    sexo.x +
    raca +
    idade_ingresso_c +
    idade_ingresso_c2 +
    dummyescolapublica +
    ano_ingresso +
    unidade_responsavel +
    enem_media,
  family = binomial(link = "logit"),
  data = base_mismatch
)

summary(logit_enem)

exp(
  cbind(
    OR = coef(logit_enem),
    confint(logit_enem)
  )
)

library(gtsummary)

tbl_merge(
  tbls = list(
    tbl_regression(logit_principal, exponentiate = TRUE),
    tbl_regression(logit_enem, exponentiate = TRUE)
  ),
  tab_spanner = c(
    "**Modelo Principal**",
    "**Robustez (ENEM)**"
  )
)



exp(cbind(
  OR = coef(logit_sem_bolsas),
  confint(logit_sem_bolsas)
))

exp(cbind(
  OR = coef(logit_modelo5),
  confint(logit_modelo5)
))

summary(logit_sem_bolsas)
summary(logit_modelo5)

# 14.5 Modelos exploratórios (NÃO UTILIZADOS NA DISSERTAÇÃO)


# Esses modelos foram estimados para investigar
# o efeito da inclusão das variáveis de assistência
# estudantil e bolsas institucionais.
#
# Como a base não informa o momento de concessão
# dos benefícios, essas variáveis podem representar
# mecanismos posteriores ao ingresso.
#
# Dessa forma, optou-se por não utilizá-las
# como especificação principal.


# Modelo com assistência estudantil

logit_assistencia <- glm(
  evento ~
    cota +
    sexo.x +
    raca +
    idade_ingresso_c +
    idade_ingresso_c2 +
    dummyescolapublica +
    bolsa_assistencia +
    ano_ingresso +
    unidade_responsavel,
  family = binomial(link = "logit"),
  data = base_final
)

# Modelo com assistência + bolsa institucional

logit_bolsas <- glm(
  evento ~
    cota +
    sexo.x +
    raca +
    idade_ingresso_c +
    idade_ingresso_c2 +
    dummyescolapublica +
    bolsa_assistencia +
    bolsa_institucional +
    ano_ingresso +
    unidade_responsavel,
  family = binomial(link = "logit"),
  data = base_final
)


# Comparações exploratórias


summary(logit_assistencia)

summary(logit_bolsas)


# Associação entre bolsas

table(
  base_final$bolsa_assistencia,
  base_final$bolsa_institucional
)

prop.table(
  table(
    base_final$bolsa_assistencia,
    base_final$bolsa_institucional
  ),
  1
)


# Associação entre cota e bolsas

prop.table(
  table(
