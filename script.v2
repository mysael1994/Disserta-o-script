############################################################
# 17. CONSTRUÇÃO DAS NOTAS DAS DISCIPLINAS
############################################################

disciplinas <- base_final %>%
  select(
    matricula,
    notas_disciplinas
  )

#str(disciplinas)
disciplinas_long <- disciplinas %>%
  mutate(
    notas_disciplinas = str_remove_all(
      notas_disciplinas,
      "^\\{|\\}$"
    )
  ) %>%
  separate_rows(
    notas_disciplinas,
    sep = "\",\""
  ) %>%
  extract(
    notas_disciplinas,
    into = c(
      "semestre",
      "codigo",
      "disciplina",
      "media"
    ),
    regex = "^([0-9]{4}\\.[12]) - ([A-Z0-9]+) - (.*) - Média: (.*)$",
    remove = FALSE
  ) %>%
  mutate(
    media = ifelse(media == "-", NA, media),
    media = as.numeric(media),
    notas_disciplinas = str_replace_all(
      notas_disciplinas,
      '"',
      ""
    )
  )
#str(disciplinas_long)
cr_semestre <- disciplinas_long %>%
  group_by(
    matricula,
    semestre
  ) %>%
  summarise(
    cr_semestre = mean(media, na.rm = TRUE),
    n_disciplinas = sum(!is.na(media)),
    .groups = "drop"
  )

#investigando o indicador por numero de disciplina
#cr_semestre2 <- cr_semestre %>%
#  filter(n_disciplinas > 0)
#summary(cr_semestre2$n_disciplinas)
#table(cr_semestre2$n_disciplinas)


cr_acumulado <- disciplinas_long %>%
  group_by(matricula) %>%
  summarise(
    cr_acumulado = mean(media, na.rm = TRUE),
    .groups = "drop"
  )
#str(cr_acumulado)

############################################################
# VERIFICAÇÃO METODOLÓGICA DO CR ACUMULADO
# Número de disciplinas cursadas por estudante
############################################################

# 1. Total de disciplinas com nota válida por estudante
disciplinas_por_aluno <- cr_semestre %>%
  filter(n_disciplinas > 0) %>%
  group_by(matricula) %>%
  summarise(
    total_disciplinas = sum(n_disciplinas, na.rm = TRUE),
    media_disciplinas_semestre = mean(n_disciplinas, na.rm = TRUE),
    n_semestres_com_nota = n(),
    .groups = "drop"
  )

# 2. Juntar com base_mismatch
base_mismatch_validacao <- base_mismatch %>%
  left_join(
    disciplinas_por_aluno,
    by = "matricula"
  )

# 3. Descritiva por cota
base_mismatch_validacao %>%
  group_by(cota) %>%
  summarise(
    media_total_disciplinas = mean(total_disciplinas, na.rm = TRUE),
    dp_total_disciplinas = sd(total_disciplinas, na.rm = TRUE),
    media_disciplinas_semestre = mean(media_disciplinas_semestre, na.rm = TRUE),
    dp_disciplinas_semestre = sd(media_disciplinas_semestre, na.rm = TRUE),
    media_semestres_com_nota = mean(n_semestres_com_nota, na.rm = TRUE),
    n = n(),
    .groups = "drop"
  )

# 4. Teste t para total de disciplinas
t.test(
  total_disciplinas ~ cota,
  data = base_mismatch_validacao
)

# 5. Teste t para média de disciplinas por semestre
t.test(
  media_disciplinas_semestre ~ cota,
  data = base_mismatch_validacao
)

# 6. Correlação entre CR acumulado e número de disciplinas
cor.test(
  base_mismatch_validacao$cr_acumulado,
  base_mismatch_validacao$total_disciplinas,
  use = "complete.obs"
)

cor.test(
  base_mismatch_validacao$cr_acumulado,
  base_mismatch_validacao$media_disciplinas_semestre,
  use = "complete.obs"
)

# 7. Modelo verificando se o efeito de cota muda ao controlar por número de disciplinas
modelo_mqo_validacao <- lm(
  cr_acumulado ~
    cota +
    sexo.x +
    raca +
    idade_ingresso +
    dummyescolapublica +
    bolsa_assistencia +
    bolsa_institucional +
    total_disciplinas+
    unidade_responsavel,
  data = base_mismatch_validacao
)

summary(modelo_mqo_validacao)
#table(base_mismatch$unidade_responsavel)
# 8. Modelo com ENEM e número de disciplinas
modelo_mqo_enem_validacao <- lm(
  cr_acumulado ~
    cota +
    enem_media +
    sexo.x +
    raca +
    idade_ingresso +
    dummyescolapublica +
    bolsa_assistencia +
    bolsa_institucional +
    total_disciplinas+
    unidade_responsavel,
  data = base_mismatch_validacao
)

summary(modelo_mqo_enem_validacao)

# 9. Comparar com seus modelos principais
summary(modelo_mqo)
summary(modelo_mqo_validacao)

summary(modelo_mqo_enem)
summary(modelo_mqo_enem_validacao)

