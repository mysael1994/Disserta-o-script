# 21. BLOCO 3 - PAREAMENTO POR ESCORE DE PROPENSÃO
############################################################

dados_psm <- base_mismatch %>%
  filter(
    complete.cases(
      cota,
      enem_media,
      sexo.x,
      raca,
      idade_ingresso,
      cr_acumulado
    )
  )

psm <- matchit(
  cota ~
    enem_media +
    sexo.x +
    raca +
    idade_ingresso,
  data = dados_psm,
  method = "nearest",
  ratio = 1
)

summary(psm)

love.plot(
  psm,
  threshold = 0.1
)

psm2 <- matchit(
  cota ~
    enem_media +
    sexo.x +
    raca +
    idade_ingresso,
  data = dados_psm,
  method = "nearest",
  ratio = 1,
  caliper = 0.2
)

summary(psm2)

dados_match <- match.data(psm2)

table(dados_match$cota)

t.test(
  cr_acumulado ~ cota,
  data = dados_match
)

modelo_psm <- lm(
  cr_acumulado ~ cota,
  data = dados_match
)

summary(modelo_psm)

modelo_psm2 <- lm(
  cr_acumulado ~
    cota +
    enem_media +
    sexo.x +
    raca +
    idade_ingresso,
  data = dados_match
)

summary(modelo_psm2)

love_plot_psm <- love.plot(
  psm2,
  threshold = 0.1,
  abs = FALSE,
  var.order = "unadjusted",
  var.names = c(
    distance = "Escore de Propensão",
    enem_media = "Nota média do ENEM",
    "sexo.x_Masculino" = "Sexo (Masculino)",
    raca_Branco = "Raça: Branco",
    "raca_Amarelo (de origem oriental)" = "Raça: Amarelo",
    raca_Indígena = "Raça: Indígena",
    raca_Pardo = "Raça: Pardo",
    raca_Preto = "Raça: Preto",
    idade_ingresso = "Idade de Ingresso"
  ),
  sample.names = c(
    "Antes do Pareamento",
    "Após Pareamento"
  ),
  title = "Balanceamento das Covariáveis Antes e Após o Pareamento",
  stars = "raw",
  xlab = "Diferenças Médias Padronizadas (SMD)"
)

love_plot_psm

saveRDS(dados_match, "dados_match_dissertacao.rds")


