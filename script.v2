############################################################
# 22. CATCH-UP - CONSTRUÇÃO DO PAINEL
############################################################

#construindo o painel - aqui ta top
painel_catchup1 <- cr_semestre %>%
  filter(
    !is.na(matricula),
    !is.na(semestre),
    !is.na(cr_semestre),
    !is.nan(cr_semestre),
    n_disciplinas > 0
  ) %>%
  arrange(
    matricula,
    semestre
  ) %>%
  group_by(matricula) %>%
  mutate(
    tempo = row_number()
  ) %>%
  ungroup()


#proximo passo
base_caracteristicas <- base_mismatch %>%
  filter(!is.na(matricula)) %>%
  select(
    matricula,
    cota,
    enem_media,
    sexo.x,
    raca,
    idade_ingresso,
    dummyescolapublica,
    bolsa_assistencia,
    bolsa_institucional,
    unidade_responsavel,
    ano_ingresso,
    periodo_ingresso
  ) %>%
  distinct(matricula, .keep_all = TRUE)


#juntando como painel
painel_catchup <- painel_catchup1 %>%
  left_join(
    base_caracteristicas,
    by = "matricula",
    relationship = "many-to-one"
  )


painel_catchup %>%
  summarise(
    sem_cota = sum(is.na(cota)),
    sem_enem = sum(is.na(enem_media)),
    sem_sexo = sum(is.na(sexo.x)),
    sem_raca = sum(is.na(raca)),
    sem_idade = sum(is.na(idade_ingresso)),
    sem_centro = sum(is.na(unidade_responsavel))
  )


# Amostra completa com CR semestral válido
painel_total <- painel_catchup

# Amostra com informações completas para o modelo com ENEM
painel_total_enem <- painel_catchup %>%
  filter(
    complete.cases(
      cota,
      tempo,
      cr_semestre,
      enem_media,
      sexo.x,
      raca,
      idade_ingresso,
      dummyescolapublica,
      bolsa_assistencia,
      bolsa_institucional,
      unidade_responsavel
    )
  )

# Amostra pareada pelo PSM com caliper
painel_match <- painel_catchup %>%
  filter(
    matricula %in% dados_match$matricula
  )




############################################################
# TABELA DESCRITIVA - EVOLUÇÃO DO CR AO LONGO DOS SEMESTRES
############################################################

tabela_catchup <- painel_total %>%
  group_by(
    tempo,
    cota
  ) %>%
  summarise(
    estudantes = n_distinct(matricula),
    cr_medio = mean(
      cr_semestre,
      na.rm = TRUE
    ),
    .groups = "drop"
  ) %>%
  mutate(
    grupo = ifelse(
      cota == 1,
      "Cotistas",
      "Não cotistas"
    )
  ) %>%
  select(
    tempo,
    grupo,
    estudantes,
    cr_medio
  )

tabela_catchup <- painel_total %>%
  group_by(
    tempo,
    cota
  ) %>%
  summarise(
    estudantes = n_distinct(matricula),
    cr_medio = mean(cr_semestre, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    grupo = if_else(
      cota == 1,
      "cotistas",
      "nao_cotistas"
    )
  ) %>%
  select(
    tempo,
    grupo,
    estudantes,
    cr_medio
  ) %>%
  pivot_wider(
    names_from = grupo,
    values_from = c(
      estudantes,
      cr_medio
    )
  ) %>%
  mutate(
    diferenca =
      cr_medio_cotistas -
      cr_medio_nao_cotistas,
    
    cr_medio_nao_cotistas =
      round(cr_medio_nao_cotistas, 3),
    
    cr_medio_cotistas =
      round(cr_medio_cotistas, 3),
    
    diferenca =
      round(diferenca, 3)
  ) %>%
  rename(
    `Semestre cursado` = tempo,
    `N não cotistas` = estudantes_nao_cotistas,
    `CR não cotistas` = cr_medio_nao_cotistas,
    `N cotistas` = estudantes_cotistas,
    `CR cotistas` = cr_medio_cotistas,
    `Diferença` = diferenca
  )

print(tabela_catchup, n = Inf)

#as regressões resultados 

