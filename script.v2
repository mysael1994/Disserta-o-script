merge2018 <- merge2018 %>%
  rename(dt_nascimento = data_nascimento)

extrair_ano <- function(x) {
  ano_str <- str_extract(x, "\\d{2,4}$")
  ano_num <- as.numeric(ano_str)
  
  ano_final <- ifelse(
    nchar(ano_str) == 4,
    ano_num,
    ifelse(ano_num <= 25, 2000 + ano_num, 1900 + ano_num)
  )
  
  return(ano_final)
}

merge2016 <- merge2016 %>%
  mutate(dt_nascimento = extrair_ano(dt_nascimento))

merge2017 <- merge2017 %>%
  mutate(dt_nascimento = extrair_ano(dt_nascimento))

merge2018 <- merge2018 %>%
  mutate(dt_nascimento = extrair_ano(dt_nascimento))

merge2019 <- merge2019 %>%
  mutate(dt_nascimento = extrair_ano(dt_nascimento))

merge2015 <- merge2015 %>%
  mutate(dt_nascimento = as.numeric(dt_nascimento))

merge2019 <- merge2019 %>%
  mutate(
    nota_corte = str_replace(nota_corte, ",", "."),
    nota_corte = as.numeric(nota_corte),
    classificacao = as.integer(classificacao)
  )

if ("nu_percentual_bonus" %in% names(merge2019)) {
  merge2019 <- merge2019 %>%
    select(-nu_percentual_bonus)
}


